<!DOCTYPE html>
<html class="dark">
  <head>
    <title><%= content_for(:title) || "Botster" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Botster">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= action_cable_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/favicon-96.png" type="image/png" sizes="96x96">
    <link rel="icon" href="/favicon.png" type="image/png" sizes="32x32">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/apple-touch-icon.png">
    <link rel="manifest" href="<%= pwa_manifest_path %>">

    <%= stylesheet_link_tag :app %>
  </head>

  <body class="bg-zinc-950 text-zinc-100 min-h-dvh font-sans antialiased flex flex-col">
    <header class="border-b border-zinc-800 bg-zinc-900/80 backdrop-blur-sm">
      <div class="mx-auto flex max-w-7xl flex-col gap-4 px-4 py-4 sm:flex-row sm:items-center sm:justify-between sm:px-6 lg:px-8">
        <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:gap-8">
          <%= link_to root_path, class: "flex items-center gap-2 text-primary-400 transition-colors hover:text-primary-300" do %>
            <svg class="size-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2z" />
            </svg>
            <span class="font-mono text-lg font-bold tracking-tight">botster</span>
          <% end %>

          <nav class="flex flex-wrap items-center gap-2">
            <%= link_to "Docs", docs_path, class: "rounded px-3 py-1.5 text-sm font-medium transition-colors #{request.path.start_with?('/docs') ? 'bg-zinc-800 text-primary-400' : 'text-zinc-400 hover:bg-zinc-800/50 hover:text-zinc-200'}" %>
            <% if user_signed_in? %>
              <%= link_to "Hubs", hubs_path, class: "rounded px-3 py-1.5 text-sm font-medium transition-colors #{request.path == hubs_path ? 'bg-zinc-800 text-primary-400' : 'text-zinc-400 hover:bg-zinc-800/50 hover:text-zinc-200'}" %>
              <%= link_to "Settings", settings_path, class: "rounded px-3 py-1.5 text-sm font-medium transition-colors #{request.path == settings_path ? 'bg-zinc-800 text-primary-400' : 'text-zinc-400 hover:bg-zinc-800/50 hover:text-zinc-200'}" %>
            <% end %>
          </nav>
        </div>

        <% if user_signed_in? %>
          <div class="flex items-center gap-4">
            <span class="text-sm font-mono text-zinc-500"><%= current_user.username || current_user.email %></span>
            <%= button_to "Logout",
                          destroy_user_session_path,
                          method: :delete,
                          class: "text-sm text-zinc-400 transition-colors hover:text-zinc-200" %>
          </div>
        <% end %>
      </div>
    </header>

    <main class="flex-1">
      <%= yield %>
    </main>

    <% unless content_for?(:no_footer) %>
      <footer class="border-t border-zinc-800 mt-auto py-6">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <p class="text-center text-xs text-zinc-600 font-mono">
            botster &middot; local-first agent platform
          </p>
        </div>
      </footer>
    <% end %>
  </body>
</html>
