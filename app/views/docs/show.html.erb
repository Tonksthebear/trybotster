<% content_for(:no_footer) { true } %>
<% content_for(:title) { "Docs - Botster" } %>

<div class="flex-1 flex min-h-0">
  <%# Desktop sidebar %>
  <nav class="hidden lg:flex flex-col w-60 shrink-0 border-r border-zinc-800 overflow-y-auto py-6 px-4">
    <%= render "docs/sidebar", sections: @sections, current_path: @path %>
  </nav>

  <%# Mobile sidebar toggle %>
  <div class="lg:hidden border-b border-zinc-800 px-4 py-3">
    <details class="group">
      <summary class="flex items-center gap-2 text-sm text-zinc-400 cursor-pointer select-none">
        <svg class="size-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
        <span>Documentation Menu</span>
        <svg class="size-3 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m6.75 9 5.25 5.25L17.25 9" />
        </svg>
      </summary>
      <div class="mt-3 pb-1">
        <%= render "docs/sidebar", sections: @sections, current_path: @path %>
      </div>
    </details>
  </div>

  <%# Content %>
  <article class="flex-1 min-w-0 overflow-y-auto py-8 px-6 sm:px-10 lg:px-16">
    <div class="max-w-3xl">
      <%= render partial: @page_partial %>
    </div>
  </article>
</div>
