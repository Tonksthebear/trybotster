<%# Rename Workspace Modal %>
<%# Text input for new workspace name, pre-populated when opened %>
<%= render Elements::DialogComponent.new(id: "rename-workspace-modal") do %>
  <div data-controller="rename-workspace-modal"
       data-rename-workspace-modal-hub-id-value="<%= Current.hub.id %>"
       class="flex flex-col">
    <%# Header %>
    <div class="px-5 py-4 border-b border-zinc-800 bg-zinc-950/50">
      <div class="flex items-center gap-3">
        <span class="size-7 rounded-md bg-primary-500/20 text-primary-400 flex items-center justify-center border border-primary-500/30">
          <%= icon "pencil", class: "size-4" %>
        </span>
        <div>
          <h3 class="text-base font-semibold text-zinc-100">Rename Workspace</h3>
          <p class="text-xs text-zinc-500 mt-0.5" data-rename-workspace-modal-target="currentName">Current name</p>
        </div>
      </div>
    </div>

    <%# Content %>
    <div class="p-5 space-y-3">
      <label class="block text-sm text-zinc-300" for="rename-workspace-input">New name</label>
      <input type="text"
             id="rename-workspace-input"
             data-rename-workspace-modal-target="input"
             data-action="keydown.enter->rename-workspace-modal#confirm"
             class="w-full rounded-md border border-zinc-700 bg-zinc-900 px-3 py-2 text-sm text-zinc-100 placeholder-zinc-500 focus:border-primary-500 focus:outline-none focus:ring-1 focus:ring-primary-500"
             placeholder="Workspace name"
             autocomplete="off" />
    </div>

    <%# Footer %>
    <div class="px-5 py-4 border-t border-zinc-800 bg-zinc-950/30 flex gap-2 justify-end">
      <%= render Elements::ButtonComponent.new("Cancel",
        color: :neutral,
        variant: :ghost,
        command: "close",
        commandfor: "rename-workspace-modal"
      ) %>
      <%= render Elements::ButtonComponent.new("Rename",
        color: :primary,
        variant: :solid,
        data: { action: "rename-workspace-modal#confirm" }
      ) %>
    </div>
  </div>
<% end %>
