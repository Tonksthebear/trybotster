<%# Move Agent to Workspace Modal %>
<%# Shows existing workspaces as clickable options, plus a text input for new workspace %>
<%= render Elements::DialogComponent.new(id: "move-agent-modal") do %>
  <div data-controller="move-agent-modal"
       data-move-agent-modal-hub-id-value="<%= Current.hub.id %>"
       class="flex flex-col">
    <%# Header %>
    <div class="px-5 py-4 border-b border-zinc-800 bg-zinc-950/50">
      <div class="flex items-center gap-3">
        <span class="size-7 rounded-md bg-primary-500/20 text-primary-400 flex items-center justify-center border border-primary-500/30">
          <%= icon "arrows-right-left", class: "size-4" %>
        </span>
        <div>
          <h3 class="text-base font-semibold text-zinc-100">Move Session</h3>
          <p class="text-xs text-zinc-500 mt-0.5" data-move-agent-modal-target="agentName">Selected session</p>
        </div>
      </div>
    </div>

    <%# Content %>
    <div class="p-5 space-y-4">
      <%# Existing workspaces list (populated dynamically) %>
      <div data-move-agent-modal-target="workspaceList" class="space-y-2"></div>

      <%# Divider %>
      <div class="flex items-center gap-3" data-move-agent-modal-target="divider">
        <div class="flex-1 border-t border-zinc-800"></div>
        <span class="text-xs text-zinc-500">or create new</span>
        <div class="flex-1 border-t border-zinc-800"></div>
      </div>

      <%# New workspace input %>
      <input type="text"
             data-move-agent-modal-target="input"
             data-action="keydown.enter->move-agent-modal#confirmNew"
             class="w-full rounded-md border border-zinc-700 bg-zinc-900 px-3 py-2 text-sm text-zinc-100 placeholder-zinc-500 focus:border-primary-500 focus:outline-none focus:ring-1 focus:ring-primary-500"
             placeholder="New workspace name"
             autocomplete="off" />
    </div>

    <%# Footer %>
    <div class="px-5 py-4 border-t border-zinc-800 bg-zinc-950/30 flex gap-2 justify-end">
      <%= render Elements::ButtonComponent.new("Cancel",
        color: :neutral,
        variant: :ghost,
        command: "close",
        commandfor: "move-agent-modal"
      ) %>
      <%= render Elements::ButtonComponent.new("Move to New",
        color: :primary,
        variant: :solid,
        data: { action: "move-agent-modal#confirmNew" }
      ) %>
    </div>
  </div>
<% end %>
