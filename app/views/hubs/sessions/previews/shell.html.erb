<!DOCTYPE html>
<html lang="en" class="h-full">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Preview</title>
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  <% if @public_preview %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags "public_preview" %>
  <% else %>
    <meta name="crypto-worker-url" content="<%= asset_path('workers/olm_crypto.js') %>">
    <meta name="crypto-wasm-js-url" content="<%= asset_path('vodozemac/vodozemac_wasm.js') %>">
    <meta name="crypto-wasm-binary-url" content="<%= asset_path('vodozemac/vodozemac_wasm_bg.wasm') %>">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  <% end %>
  <style>
    .preview-frame {
      width: 100%;
      height: 100%;
      border: none;
    }
    .status-bar {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      padding: 8px 16px;
      background: rgba(17, 24, 39, 0.95);
      border-bottom: 1px solid rgba(255, 255, 255, 0.1);
      display: flex;
      align-items: center;
      justify-content: space-between;
      font-family: system-ui, -apple-system, sans-serif;
      font-size: 13px;
      z-index: 1000;
    }
    .status-bar.connected {
      background: rgba(5, 46, 22, 0.95);
      border-bottom-color: rgba(34, 197, 94, 0.3);
    }
    .status-bar.error {
      background: rgba(69, 10, 10, 0.95);
      border-bottom-color: rgba(239, 68, 68, 0.3);
    }
    .status-text {
      color: #9ca3af;
    }
    .status-bar.connected .status-text {
      color: #86efac;
    }
    .status-bar.error .status-text {
      color: #fca5a5;
    }
    .preview-container {
      position: fixed;
      top: 41px;
      left: 0;
      right: 0;
      bottom: 0;
    }
  </style>
</head>
<body class="h-full bg-zinc-950">
  <%# Connection container — uses public-preview controller for unencrypted, preview for E2E %>
  <% controller_name = @public_preview ? "public-preview" : "preview" %>
  <div id="preview-connection"
       data-controller="<%= controller_name %>"
       data-<%= controller_name %>-hub-id-value="<%= Current.hub.id %>"
       data-<%= controller_name %>-session-uuid-value="<%= Current.session_uuid %>"
       data-<%= controller_name %>-scope-value="<%= @scope %>"
       data-<%= controller_name %>-initial-url-value="<%= @initial_url %>"
       <% if @preview_port %>data-<%= controller_name %>-port-value="<%= @preview_port %>"<% end %>>

    <%# Status bar %>
    <div class="status-bar">
      <span data-<%= controller_name %>-target="status" class="status-text">Connecting...</span>
      <% unless @public_preview %>
        <a href="<%= hub_session_path(Current.hub, Current.session_uuid) %>"
           class="text-zinc-500 hover:text-zinc-300 text-xs">
          Back to Terminal
        </a>
      <% end %>
    </div>

    <%# Error display %>
    <div data-<%= controller_name %>-target="error" class="hidden text-red-400 text-sm px-4 py-2"></div>

    <%# Preview iframe - loads proxied content %>
    <div class="preview-container">
      <%# Public preview: drop allow-same-origin to isolate untrusted forwarded content
          from the trybotster.com origin (cookies, localStorage, authenticated endpoints).
          Authenticated preview keeps allow-same-origin since the user owns the hub. %>
      <iframe
        data-<%= controller_name %>-target="iframe"
        class="preview-frame"
        sandbox="allow-scripts allow-forms allow-popups allow-modals<%= ' allow-same-origin' unless @public_preview %>">
      </iframe>
    </div>
  </div>
</body>
</html>
