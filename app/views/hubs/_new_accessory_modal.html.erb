<%# New Accessory Modal %>
<%# Select an accessory config and workspace, then spawn it %>
<%= render Elements::DialogComponent.new(id: "new-accessory-modal") do %>
  <div data-controller="new-accessory-modal"
       data-new-accessory-modal-hub-id-value="<%= Current.hub.id %>"
       class="flex flex-col">
    <%# Header %>
    <div class="px-5 py-4 border-b border-zinc-800 bg-zinc-950/50">
      <div class="flex items-center gap-3">
        <span class="size-7 rounded-md bg-zinc-700/50 text-zinc-400 flex items-center justify-center border border-zinc-600/30">
          <%= icon "command-line", class: "size-4" %>
        </span>
        <div>
          <h3 class="text-base font-semibold text-zinc-100">New Accessory</h3>
          <p class="text-xs text-zinc-500 mt-0.5">Start a plain terminal session</p>
        </div>
      </div>
    </div>

    <%# Content %>
    <div class="p-5 space-y-4">
      <div data-new-accessory-modal-target="targetSection" class="hidden">
        <div class="flex items-center gap-2 mb-2">
          <%= icon "folder", class: "size-4 text-zinc-500" %>
          <label class="text-xs font-medium text-zinc-400 uppercase tracking-wider">Spawn Target</label>
        </div>
        <select data-new-accessory-modal-target="targetSelect"
                data-action="change->new-accessory-modal#selectTarget"
                class="w-full px-3 py-2.5 bg-zinc-950 border border-zinc-700 rounded text-zinc-100 text-sm focus:outline-hidden focus:border-primary-500 focus:ring-1 focus:ring-primary-500/50 transition-colors">
        </select>
        <p data-new-accessory-modal-target="targetPrompt" class="text-xs text-zinc-600 mt-1">Choose a spawn target before selecting an accessory configuration.</p>
      </div>

      <div data-new-accessory-modal-target="configSection" class="hidden space-y-4">
        <%# Accessory config list - populated dynamically %>
        <div>
          <div class="flex items-center gap-2 mb-2">
            <%= icon "command-line", class: "size-4 text-zinc-500" %>
            <label class="text-xs font-medium text-zinc-400 uppercase tracking-wider">Accessory</label>
          </div>
          <div data-new-accessory-modal-target="accessoryList" class="space-y-1.5">
            <p class="text-sm text-zinc-500 text-center py-4">Choose a spawn target first</p>
          </div>
        </div>

        <%# No accessories configured warning %>
        <div data-new-accessory-modal-target="noConfigWarning" class="hidden px-3 py-2.5 bg-amber-500/10 border border-amber-500/20 rounded-lg">
          <div class="flex items-start gap-2.5">
            <svg class="size-4 text-amber-400 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z" />
            </svg>
            <div>
              <p class="text-xs font-medium text-amber-300">No accessories configured</p>
              <p class="text-xs text-zinc-500 mt-0.5">Add accessory configurations in
                <span class="text-zinc-400">Settings</span> to define terminal sessions.</p>
            </div>
          </div>
        </div>

        <%# Workspace select - populated dynamically %>
        <div data-new-accessory-modal-target="workspaceSection" class="hidden">
          <div class="flex items-center gap-2 mb-2">
            <svg class="size-4 text-zinc-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
            </svg>
            <label class="text-xs font-medium text-zinc-400 uppercase tracking-wider">Workspace</label>
          </div>
          <select data-new-accessory-modal-target="workspaceSelect"
                  class="w-full px-3 py-2.5 bg-zinc-950 border border-zinc-700 rounded text-zinc-100 text-sm focus:outline-hidden focus:border-primary-500 focus:ring-1 focus:ring-primary-500/50 transition-colors">
          </select>
          <p class="text-xs text-zinc-600 mt-1">Which workspace to add this accessory to</p>
        </div>
      </div>
    </div>

    <%# Footer %>
    <div class="px-5 py-4 border-t border-zinc-800 bg-zinc-950/30 flex gap-2 justify-end">
      <%= render Elements::ButtonComponent.new("Cancel",
        color: :neutral,
        variant: :ghost,
        command: "close",
        commandfor: "new-accessory-modal"
      ) %>
      <%= render Elements::ButtonComponent.new("Start Accessory",
        color: :primary,
        variant: :solid,
        data: { action: "new-accessory-modal#submit", new_accessory_modal_target: "submitButton" },
        disabled: true
      ) %>
    </div>
  </div>
<% end %>
