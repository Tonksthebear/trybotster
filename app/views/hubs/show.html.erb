<div class="h-full flex flex-col overflow-hidden">
  <%# Header %>
  <div class="shrink-0 border-b border-zinc-800 bg-zinc-900/50">
    <div class="px-4 py-4 lg:py-6">
      <div class="flex items-start justify-between gap-4">
        <div class="min-w-0">
          <h1 class="text-xl lg:text-2xl font-bold text-zinc-100 font-mono truncate"><%= Current.hub.name %></h1>
          <p class="text-sm text-zinc-500 mt-1 truncate">
            <%= Current.hub.identifier %>
          </p>
        </div>

        <%# Connection status %>
        <div data-controller="react-mount"
             data-component="ConnectionStatus"
             data-props='<%= { hubId: Current.hub.id.to_s }.to_json %>'>
        </div>
      </div>
    </div>
  </div>

  <%# Content %>
  <div class="flex-1 overflow-y-auto">
    <div class="max-w-3xl mx-auto px-4 py-6 lg:py-8">
      <%# Hub Info Card %>
      <div class="bg-zinc-900/50 border border-zinc-800 rounded-lg p-4 lg:p-6 mb-6">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-sm font-medium text-zinc-400 uppercase tracking-wider">Hub Information</h2>
          <div class="flex items-center gap-2">
            <%= link_to hub_settings_path(Current.hub),
                  class: "inline-flex items-center gap-1.5 px-3 py-1.5 text-sm font-medium text-zinc-400 hover:text-zinc-200 bg-zinc-800/50 hover:bg-zinc-800 border border-zinc-700/50 rounded-lg transition-colors" do %>
              <%= icon "cog-6-tooth", class: "size-3.5" %>
              <span>Settings</span>
            <% end %>
            <div data-controller="react-mount"
                 data-component="ShareHub"
                 data-props='<%= { hubId: Current.hub.id.to_s }.to_json %>'>
            </div>
          </div>
        </div>
        <dl class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <dt class="text-xs text-zinc-500">Identifier</dt>
            <dd class="text-sm text-zinc-200 font-mono mt-1 truncate"><%= Current.hub.identifier %></dd>
          </div>
          <div>
            <dt class="text-xs text-zinc-500">Name</dt>
            <dd class="text-sm text-zinc-200 font-mono mt-1 truncate"><%= Current.hub.name %></dd>
          </div>
          <div>
            <dt class="text-xs text-zinc-500">Status</dt>
            <dd class="text-sm mt-1 flex items-center gap-2">
              <span class="size-2 rounded-full <%= Current.hub.active? ? 'bg-success-500' : 'bg-zinc-600' %>"></span>
              <span class="text-zinc-200"><%= Current.hub.active? ? "Online" : "Offline" %></span>
            </dd>
          </div>
          <div>
            <dt class="text-xs text-zinc-500">Last Seen</dt>
            <dd class="text-sm text-zinc-200 mt-1">
              <% if Current.hub.last_seen_at %>
                <%= time_ago_in_words(Current.hub.last_seen_at) %> ago
              <% else %>
                Never
              <% end %>
            </dd>
          </div>
        </dl>
      </div>

      <%# Workspaces Section %>
      <div data-controller="react-mount"
           data-component="App"
           data-props='<%= { hubId: Current.hub.id.to_s, surface: "panel" }.to_json %>'
           id="react-workspace-panel"
           class="bg-zinc-900/50 border border-zinc-800 rounded-lg p-4 lg:p-6">
      </div>
    </div>
  </div>

</div>
