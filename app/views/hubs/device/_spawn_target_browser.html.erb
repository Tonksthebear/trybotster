<% payload = spawn_target_browser_payload(hub) %>

<section class="bg-zinc-900/50 border border-zinc-800 rounded-lg p-4 lg:p-6 mb-6"
         data-controller="spawn-target-browser"
         data-spawn-target-browser-hub-id-value="<%= hub.id %>"
         data-spawn-target-browser-current-hub-context-value="<%= json_escape(payload[:current_hub_context].to_json) %>"
         data-spawn-target-browser-home-path-value="<%= payload[:home_path] %>"
         data-spawn-target-browser-targets-value="<%= json_escape(payload[:targets].to_json) %>">
  <div class="flex items-start justify-between gap-4 mb-4">
    <div>
      <h2 class="text-sm font-medium text-zinc-400 uppercase tracking-wider">Admitted Spawn Targets</h2>
      <p class="text-sm text-zinc-300 mt-2">
        Manage device-scoped spawn targets and stage additional admissions from one place.
      </p>
    </div>
    <span class="inline-flex items-center rounded-full border border-emerald-500/20 bg-emerald-500/10 px-2.5 py-1 text-[11px] font-medium text-emerald-300">
      Target-first runtime
    </span>
  </div>

  <div class="rounded-lg border border-zinc-800 bg-zinc-950/60 px-4 py-3 mb-5">
    <div class="flex items-center gap-2 mb-1">
      <span class="inline-flex size-6 items-center justify-center rounded-md bg-zinc-800 text-zinc-300 border border-zinc-700">
        <%= icon "command-line", class: "size-3.5" %>
      </span>
      <p class="text-xs font-medium uppercase tracking-wider text-zinc-500"><%= payload[:current_hub_context][:label] %></p>
    </div>
    <p class="text-sm font-medium text-zinc-100"><%= payload[:current_hub_context][:name] %></p>
    <p class="text-xs text-zinc-500 mt-1"><%= payload[:current_hub_context][:summary] %></p>
  </div>

  <div class="grid gap-5 xl:grid-cols-[minmax(0,1fr)_18rem]">
    <div class="min-w-0">
      <label class="block text-xs font-medium uppercase tracking-wider text-zinc-500 mb-2" for="spawn-target-filter">
        Filter Targets
      </label>
      <input id="spawn-target-filter"
             type="text"
             placeholder="Filter by name or path"
             data-spawn-target-browser-target="filterInput"
             data-action="input->spawn-target-browser#filter"
             class="w-full px-3 py-2 bg-zinc-950 border border-zinc-700 rounded text-zinc-100 placeholder-zinc-600 text-sm focus:outline-hidden focus:border-primary-500 focus:ring-1 focus:ring-primary-500/50 transition-colors">

      <div class="mt-4 space-y-3" data-spawn-target-browser-target="list"></div>

      <div data-spawn-target-browser-target="emptyState"
           class="hidden rounded-lg border border-dashed border-zinc-700 bg-zinc-950/50 px-4 py-5">
        <p class="text-sm font-medium text-zinc-200">No admitted spawn targets yet</p>
        <p class="text-xs text-zinc-500 mt-1">
          Admit a directory below. Only admitted targets can be used by runtime flows.
        </p>
      </div>
    </div>

    <aside class="space-y-4">
      <div class="rounded-lg border border-zinc-800 bg-zinc-950/60 px-4 py-4">
        <h3 class="text-xs font-medium uppercase tracking-wider text-zinc-500 mb-3">Selected Target</h3>
        <p data-spawn-target-browser-target="selectedName" class="text-sm font-medium text-zinc-100">No target selected</p>
        <p data-spawn-target-browser-target="selectedPath" class="text-xs text-zinc-500 mt-1">
          Admitted targets are device-scoped and immediately available to runtime flows.
        </p>
        <p data-spawn-target-browser-target="selectedHint" class="text-xs text-amber-300/90 mt-3">
          <%= payload[:current_hub_context][:integration_note] %>
        </p>
      </div>

      <div class="rounded-lg border border-zinc-800 bg-zinc-950/60 px-4 py-4">
        <h3 class="text-xs font-medium uppercase tracking-wider text-zinc-500 mb-3">Admit Spawn Target</h3>

        <label class="block text-xs text-zinc-500 mb-1" for="spawn-target-name">Name</label>
        <input id="spawn-target-name"
               type="text"
               placeholder="trybotster"
               data-spawn-target-browser-target="nameInput"
               class="w-full px-3 py-2 bg-zinc-950 border border-zinc-700 rounded text-zinc-100 placeholder-zinc-600 text-sm focus:outline-hidden focus:border-primary-500 focus:ring-1 focus:ring-primary-500/50 transition-colors">

        <label class="block text-xs text-zinc-500 mt-3 mb-1" for="spawn-target-path">Absolute Path</label>
        <input id="spawn-target-path"
               type="text"
               placeholder="/Users/exampleuser/Rails/trybotster"
               list="spawn-target-path-suggestions"
               data-spawn-target-browser-target="pathInput"
               data-action="focus->spawn-target-browser#refreshPathSuggestions input->spawn-target-browser#pathInputChanged change->spawn-target-browser#pathInputChanged keydown.enter->spawn-target-browser#admitTarget"
               class="w-full px-3 py-2 bg-zinc-950 border border-zinc-700 rounded text-zinc-100 placeholder-zinc-600 text-sm font-mono focus:outline-hidden focus:border-primary-500 focus:ring-1 focus:ring-primary-500/50 transition-colors">
        <datalist id="spawn-target-path-suggestions" data-spawn-target-browser-target="pathSuggestions"></datalist>

        <p class="text-xs text-zinc-500 mt-2">
          Start typing an absolute path to browse directories on this device. Only explicit admission grants runtime access.
        </p>

        <button type="button"
                data-action="spawn-target-browser#admitTarget"
                class="mt-3 w-full rounded-lg border border-primary-500/30 bg-primary-500/10 px-3 py-2 text-sm font-medium text-primary-300 hover:bg-primary-500/15 transition-colors">
          Admit Spawn Target
        </button>

        <p data-spawn-target-browser-target="feedback" class="text-xs text-zinc-500 mt-2 min-h-4"></p>
      </div>
    </aside>
  </div>
</section>
